# ── Required ──
JWT_SECRET_KEY=change-me-to-a-random-string
POSTGRES_USER=eventra_user
POSTGRES_PASSWORD=change-me-to-a-strong-database-password

# Google OAuth 2.0 (required for student login)
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/oauth/google/callback
OAUTH_FRONTEND_URL=https://yourdomain.com

# Resend email API (required for registration notifications)
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM=Eventra <noreply@yourdomain.com>

# Public web origin allowed by the gateway
CORS_ORIGINS=https://yourdomain.com

# ── Optional (defaults shown) ──
# FRONTEND_PORT=80
# GUNICORN_WORKERS=2

{
  "info": {
    "name": "Eventra API — Alpha",
    "description": "University Event Management Platform — Alpha collection covering Gateway, Auth, Events, and Registrations services.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5050", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Gateway",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register — Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@usv.ro\",\n  \"password\": \"student123\",\n  \"full_name\": \"Ion Popescu\",\n  \"role\": \"student\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Register — Organizer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"organizer@usv.ro\",\n  \"password\": \"org123\",\n  \"full_name\": \"Maria Ionescu\",\n  \"role\": \"organizer\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.collectionVariables.set('access_token', json.access_token);",
                  "  console.log('Token saved to collection variable.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"organizer@usv.ro\",\n  \"password\": \"org123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "List Published Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/",
              "host": ["{{base_url}}"],
              "path": ["events", ""]
            }
          },
          "response": []
        },
        {
          "name": "Get Event by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/events/1",
              "host": ["{{base_url}}"],
              "path": ["events", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Create Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Flask Workshop\",\n  \"description\": \"Intro to Flask microservices architecture.\",\n  \"location\": \"Lab A101, Corp C\",\n  \"category\": \"academic\",\n  \"participation_mode\": \"physical\",\n  \"start_datetime\": \"2026-04-10T10:00:00\",\n  \"end_datetime\": \"2026-04-10T12:00:00\",\n  \"capacity\": 50,\n  \"is_published\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/events/",
              "host": ["{{base_url}}"],
              "path": ["events", ""]
            }
          },
          "response": []
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Flask Workshop — Updated\",\n  \"capacity\": 80,\n  \"is_published\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/events/1",
              "host": ["{{base_url}}"],
              "path": ["events", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/events/1",
              "host": ["{{base_url}}"],
              "path": ["events", "1"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Registrations",
      "item": [
        {
          "name": "Register for Event",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_id\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/registrations/",
              "host": ["{{base_url}}"],
              "path": ["registrations", ""]
            }
          },
          "response": []
        },
        {
          "name": "My Registrations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/registrations/my",
              "host": ["{{base_url}}"],
              "path": ["registrations", "my"]
            }
          },
          "response": []
        },
        {
          "name": "Registrations for Event",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/registrations/event/1",
              "host": ["{{base_url}}"],
              "path": ["registrations", "event", "1"]
            }
          },
          "response": []
        },
        {
          "name": "Cancel Registration",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{base_url}}/registrations/1/cancel",
              "host": ["{{base_url}}"],
              "path": ["registrations", "1", "cancel"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}

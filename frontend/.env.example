# API gateway URL (Vite dev proxy target)
# Docker: http://gateway:5000 | Local: http://localhost:5050
VITE_API_TARGET=http://localhost:5050

# Public API gateway URL used by deployed static builds, e.g. Vercel
# Leave empty for local Docker/Nginx where /api is proxied by the frontend container.
# VITE_API_BASE_URL=https://api.yourdomain.com

# OAuth base URL (optional; defaults to VITE_API_BASE_URL or /api)
VITE_OAUTH_BASE=http://localhost:5051

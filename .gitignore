# ─── Python ───────────────────────────────────────────────────────────────────
venv/
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ─── Environment ──────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Flask / SQLite ───────────────────────────────────────────────────────────
instance/
*.db
*.sqlite3

# ─── Services (nested venvs, caches, envs) ────────────────────────────────────
services/*/venv/
services/*/.venv/
services/**/__pycache__/
services/**/*.py[cod]
services/*/.env
services/*/.env.*
!services/*/.env.example
services/*/instance/

# ─── Testing & Coverage ───────────────────────────────────────────────────────
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/

# ─── Node / Frontend ──────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.*
!frontend/.env.example

# ─── Sphinx Docs ──────────────────────────────────────────────────────────────
services/*/docs/build/
docs/build/

# ─── IDEs & OS ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Docker ───────────────────────────────────────────────────────────────────
*.override.yml
